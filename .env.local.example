# Ganti dengan konfigurasi Firebase proyek Anda
VITE_FIREBASE_API_KEY="AIzaSy...YOUR_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="1:your-app-id"
VITE_FIREBASE_MEASUREMENT_ID="G-your-measurement-id"

# Ganti dengan konfigurasi Cloudinary Anda
VITE_CLOUDINARY_CLOUD_NAME="your-cloud-name"
VITE_CLOUDINARY_API_KEY="your-api-key"